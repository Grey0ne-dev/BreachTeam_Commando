# target to generate assembly for a file
tests/migration_manager_test.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/migration_manager_test.dir/build.make CMakeFiles/migration_manager_test.dir/tests/migration_manager_test.cpp.s
.PHONY : tests/migration_manager_test.cpp.s

