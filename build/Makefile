	$(MAKE) $(MAKESILENT) -f CMakeFiles/protocol_test.dir/build.make CMakeFiles/protocol_test.dir/tests/protocol_test.cpp.o
.PHONY : tests/protocol_test.cpp.o

tests/protocol_test.i: tests/protocol_test.cpp.i
